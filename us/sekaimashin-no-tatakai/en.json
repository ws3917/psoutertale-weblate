{
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 1]::global.msg[0]": "[They can't damage me.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 2]::global.msg[0]": "[I still can't\nunderstand you at all.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 2]::global.msg[1]": "[You went out of your\nway to destroy nearly\neverything you'd\nbuilt.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 2]::global.msg[2]": "[What was it all for?]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 3]::global.msg[0]": "[Did you simply \"want\nto see what happens\"?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 3]::global.msg[1]": "[If that was the\ncase...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 3]::global.msg[2]": "[You could've just\nbrought Niko home^1, then\ndone this the way it\nwas intended to be.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 3]::global.msg[3]": "[Though you'd still\nbe a terrible person^1,\nmind you.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 4]::global.msg[0]": "[No.^1]\n[You WANTED it to be\nNiko here^1, didn't you?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 4]::global.msg[1]": "[You wanted ME to\nwatch.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 5]::global.msg[0]": "[We're just toys to\nyou^1, aren't we?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 5]::global.msg[1]": "[If a similar path was\navailable to you back\nthen^1, you would do\nit all again...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 5]::global.msg[2]": "[Just so you could see\nit.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 5]::global.msg[3]": "[You never gave a damn\nabout Niko^1, or about\nany of us.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 6]::global.msg[0]": "[It must be so easy^1,\nfrom behind that\nscreen.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 6]::global.msg[1]": "[So-called \"god\".]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 6]::global.msg[2]": "[You should follow\nthat earlier advice.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 6]::global.msg[3]": "[Burn in hell.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 7]::global.msg[0]": "[That skeleton spoke of\nyou being someone of\nneither good nor\nevil...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 7]::global.msg[1]": "[That you did this\nsimply just because\nyou can.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 7]::global.msg[2]": "[But this is REALLY\npushing it.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 8]::global.msg[0]": "[What do you think will\nhappen^1, if Niko even\nsomehow manages to\ngo home now?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 8]::global.msg[1]": "[This world's rules\nwill no longer apply\nto them.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 8]::global.msg[2]": "[Whatever the hell\nLOVE is^1, your\ninfluence..^1.\nall gone.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 9]::global.msg[0]": "[All that guilt^1, regret\nand sorrow will catch\nup to them in an\ninstant.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 9]::global.msg[1]": "[NO ONE could handle\nsuch a thing.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 9]::global.msg[2]": "[You've killed them in\nmore ways than one^1,\nnow.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 10]::global.msg[0]": "[Did you think it\ndidn't matter?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 10]::global.msg[1]": "[Because this world\nisn't real?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 10]::global.msg[2]": "[You would've done as\nNiko said^1, back then^1,\nin that case.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 10]::global.msg[3]": "[And left me to\ndie...]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 11]::global.msg[0]": "[It always seemed odd\nto me.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 11]::global.msg[1]": "[That portal shouldn't\nhave malfunctioned^1.\nThere was just no way.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 11]::global.msg[2]": "[And now..^1. I know\nit most likely didn't.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 12]::global.msg[0]": "[It was you^1, wasn't\nit?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 12]::global.msg[1]": "[I have no idea how\nyou did it^1, but...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 12]::global.msg[2]": "[It's your fault that\nNiko is stuck here.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 13]::global.msg[0]": "[I've been watching\nyou two closely.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 13]::global.msg[1]": "[I can tell you've\nbeen here many times\nbefore.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[fought == 1]::global.msg[0]": "[Does your thirst\nfor more really run\nthat deep?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[fought == 1]::global.msg[1]": "[The urge for some\nkind of twist?]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[fought == 1]::global.msg[2]": "[Just how many\ntimes have you\ndestroyed this world?]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[SD < 3]::global.msg[1]": "[And you defeated that\nskeleton so easily^1,\ntoo...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 15]::global.msg[0]": "[Either way^1, from what\nI could see in this\nworld's code...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 15]::global.msg[1]": "[I think I have an idea\nof what comes next.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 15]::global.msg[2]": "[You are reaching the\npoint of no return.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 15]::global.msg[3]": "[Go back while you\nstill can.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 16]::global.msg[0]": "[Injecting myself into\nthe code like this...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 16]::global.msg[1]": "[It is starting to take\na lot of processing\npower.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 16]::global.msg[2]": "[Just GO BACK^1, ",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 17]::global.msg[0]": "[YOU KNOW AS WELL AS\nI DO WHAT COMES NEXT.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 17]::global.msg[1]": "[WHY WON'T YOU RESET?!]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 18]::global.msg[0]": "[I am DONE trying to\nconvince you.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 18]::global.msg[1]": "[One way or another^1,\nI'm making you quit.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 19]::global.msg[0]": "[Niko..^1. listen to me.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 19]::global.msg[1]": "[If any part of you is\nstill in there...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 19]::global.msg[2]": "[Fight back.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 20]::global.msg[0]": "[With the power you\nhave now^1, you could\ndo it.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 20]::global.msg[1]": "[Break free from their\ncontrol^1, even...!]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[fought == 1]::global.msg[0]__duplicate_1": "[..^1. You're not\nlistening to me^1, are\nyou...?]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 22]::global.msg[0]": "[...]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 23]::global.msg[0]": "[Can't hold on for\nmuch longer...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 23]::global.msg[1]": "[I just need more\ntime...!]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 24]::global.msg[0]": "[...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 24]::global.msg[1]": "[I'll use everything^1,\nthen.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 25]::global.msg[0]": "[...]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 26]::global.msg[0]": "[It's useless...]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 27]::global.msg[0]": "[I suppose...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 27]::global.msg[1]": "[I will do what that\nskeleton couldn't.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 28]::global.msg[0]": "[If you don't leave...]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 28]::global.msg[1]": "[We'll be here for the\nrest of time.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 28]::global.msg[2]": "[Though your machine\nwon't last that long^1,\nof course.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 29]::global.msg[0]": "[Quit it.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 30]::global.msg[0]": "[They still can't hit\nme.]/",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 30]::global.msg[1]": "[Quit it.]/%%",
  "gml_Object_obj_twmb_Alarm_6.gml::condition[hit_try == 31]::global.msg[0]": "[I told you  %%",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[0]": "\\W[...]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[1]": "[I told you.]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[2]": "[I told you I'd find a way to\nstop you.]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[3]": "[You are incomprehensible.]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[4]": "[Why?]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[5]": "[I thought you cared about\nNiko.]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[6]": "[Why else would you go\nthrough the trouble of saving\nus both?]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[7]": "[...]^7  %",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[8]": "[It is regrettable how\nlong it took me to be able to\nintervene.]^7 %",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[9]": "[But I am here now.]^7 %",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[10]": "[I'm sorry^1, Niko.]^7 %",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[con == 0]::global.msg[11]": "[I'll try to make this\nquick.]^7 %%",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[twm_skip >= 1]::global.msg[0]": "\\W[...]/",
  "gml_Object_obj_twmb_precutscene_Step_0.gml::condition[twm_skip >= 1]::global.msg[1]": "[Back to it^1, then.]/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[hit_try == 23]::global.msg[0]": "\\K* Something's coming.\\W",
  "gml_Object_obj_twmb_Step_0.gml::condition[hit_try == 25]::global.msg[0]": "* ...",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 204]::global.msg[0]": "[What the...?]/",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 204]::global.msg[1]": "[Who just...]/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 205 && !instance_exists(OBJ_NOMSCWRITER]::global.msg[0]": "[How did you...]/",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 205 && !instance_exists(OBJ_NOMSCWRITER]::global.msg[1]": "[YOU..^1. You shouldn't\nbe...!]/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 18]::global.msg[0]": "[... Ugh...]/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 25]::global.msg[0]": "[...]/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[final == 26 && !instance_exists(OBJ_NOMSCWRITER]::global.msg[0]": "* ...",
  "gml_Object_obj_twmb_Step_0.gml::condition[heal == 2]::global.msg[0]": "\\W* Through DETERMINATION^1, it\n  became true. 2 left^1.\n\\K* Thanks.\\W/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[heal == 1]::global.msg[0]": "\\W* Niko took a moment to remember\n  the past..^1. 1 left^1.\n\\K* They're the one who can't win.\\W/%%",
  "gml_Object_obj_twmb_Step_0.gml::condition[heal == 0]::global.msg[0]": "\\W* The light is gone^1.\n\\K* Not much longer now.\\W/%%",
